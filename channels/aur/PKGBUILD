# Maintainer: imix <imix@github>
pkgname=rpnpad-bin
pkgver=0.2.2
pkgrel=1
pkgdesc="An HP48-style RPN calculator for the terminal"
arch=('x86_64')
url="https://github.com/imix/rpnpad"
license=('MIT')
provides=('rpnpad')
conflicts=('rpnpad')
source_x86_64=("rpnpad-${pkgver}-x86_64.tar.gz::https://github.com/imix/rpnpad/releases/download/v${pkgver}/rpnpad-x86_64-unknown-linux-gnu.tar.gz")
sha256sums_x86_64=('SKIP')

package() {
    install -Dm755 "${srcdir}/rpnpad" "${pkgdir}/usr/bin/rpnpad"
}
